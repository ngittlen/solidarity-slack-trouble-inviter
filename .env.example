# Bot token from your Slack App
# Requires bot scopes: chat:write, users:read, users:read.email
# Found at: api.slack.com/apps > your app > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# OAuth credentials for Sign in with Slack (used to protect /pending)
# Found at: api.slack.com/apps > your app > Basic Information > App Credentials
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# Comma-separated list of Slack user IDs allowed to access /pending
# Find a user's ID: open their profile in Slack > ... menu > Copy member ID
SLACK_ALLOWED_USER_IDS=U012AB3CD,U012AB3CE

# The Slack channel ID (not name) to post volunteer notifications to
# Right-click the channel in Slack > View channel details > scroll to bottom
SLACK_TRACKING_CHANNEL_ID=C012AB3CD

# Turso database credentials
# Found at: app.turso.tech > your database > Connect
# For local development use: TURSO_DATABASE_URL=file:local.db (TURSO_AUTH_TOKEN not required)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Secret appended to the solidarity.tech webhook URL as ?secret=<value>
WEBHOOK_SECRET=your-webhook-secret-here

# Secret used to sign session cookies
SESSION_SECRET=your-session-secret-here

# Public URL of this app (used to build the Slack OAuth redirect URI)
APP_URL=https://your-app.fly.dev

# Port for the HTTP server (default: 3000)
PORT=3000

# --- Local development only ---
# Set to your Slack user ID to bypass Slack OAuth when running locally.
# When set, visiting /pending auto-creates a session without hitting Slack.
# The SLACK_* OAuth vars and APP_URL are not required when this is set.
# DEV_SLACK_USER_ID=U012AB3CD